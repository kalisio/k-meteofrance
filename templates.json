{
  "arpege-isobaric": {
    "variables": {
      "lon": "longitude",
      "lat": "latitude",
      "level": "ATTRIBUTES.GRIB_typeOfLevel",
      "time": "valid_time"
    },
    "concat_dim": "step",
    "float64_to_float32": true,
    "pipelines": {
      "preprocess": [
        { "type": "process", "name": "load_and_merge_from_grib", "params": {
          "discriminator": ["IP1", "IP2", "IP3"],
          "dataset_backend_kwargs": [
            {"filter_by_keys": {"shortName": ["r", "z", "t"]}},
            {"filter_by_keys": {"shortName": ["wdir", "ws", "w"]}},
            {"filter_by_keys": {"shortName": ["clwc", "ciwc", "tke"]}}
          ]
        }},
        { "type": "process", "name": "keep_variables", "params": { "keep_vars": ["r", "z", "t", "wdir", "ws", "w", "clwc", "ciwc", "tke"]} },
        { "type": "process", "name": "rename_variables", "params": { "renameMap": {
          "r": "relativeHumidity",
          "z": "geopotential",
          "t": "temperature", 
          "wdir": "windDirection",
          "ws": "windSpeed",
          "w": "verticalVelocity",
          "clwc": "cloudLiquidWaterContent",
          "ciwc": "cloudIceWaterContent",
          "tke": "turbulentKineticEnergy"
        } } },
        "unify_chunks",
        "save",
        "clean"
      ]
    }
  },
  "arome-isobaric": {
    "variables": {
      "lon": "longitude",
      "lat": "latitude",
      "level": "isobaricInhPa",
      "time": "valid_time"
    },
    "concat_dim": "step",
    "float64_to_float32": true,
    "pipelines": {
      "preprocess": [
        { "type": "process", "name": "load_and_merge_from_grib", "params": {
          "discriminator": ["IP1", "IP2", "IP3", "IP4"],
          "dataset_backend_kwargs": [
            {"filter_by_keys": {"shortName": ["r", "z", "t"]}},
            {"filter_by_keys": {"shortName": ["clwc", "ciwc"]}},
            {"filter_by_keys": {"shortName": ["wdir", "ws", "w"]}},
            {"filter_by_keys": {"shortName": "tke"}}]
        }},
        { "type": "process", "name": "keep_variables", "params": { "keep_vars": ["r", "z", "t", "wdir", "ws", "w", "clwc", "ciwc", "tke"]} },
        { "type": "process", "name": "rename_variables", "params": { "renameMap": {
          "r": "relativeHumidity",
          "z": "geopotential",
          "t": "temperature", 
          "wdir": "windDirection",
          "ws": "windSpeed",
          "w": "verticalVelocity",
          "clwc": "cloudLiquidWaterContent",
          "ciwc": "cloudIceWaterContent",
          "tke": "turbulentKineticEnergy"
        } } },
        "unify_chunks",
        "save",
        "clean"
      ]
    }
  },
  "surface": {
    "variables": {
      "lon": "longitude",
      "lat": "latitude",
      "time": "step"
    },
    "concat_dim": "step",
    "referenceTime": {
      "variable": "time"
    },
    "float64_to_float32": true,
    "pipelines": {
      "preprocess": [
        { "type": "process", "name": "load_and_merge_from_grib", "params": { "discriminator": ["SP1"] }},
        { "type": "process", "name": "keep_variables", "params": { "keep_vars": ["efg10", "fg10", "nfg10", "r2", "si10", "t2m", "tp", "tsnowp", "u10", "v10", "wdir10"] }},
        { "type": "process", "name": "rename_variables", "params": { "renameMap": {
          "efg10": "eastwardWindGust10m",
          "fg10": "windGust10m",
          "nfg10": "northwardWindGust10m",
          "r2": "relativeHumidity2m",
          "si10": "windSpeed10m",
          "t2m": "temperature2m",
          "tp": "totalPrecipitation",
          "tsnowp": "totalSnowPrecipitation",
          "u10": "uWind10m",
          "v10": "vWind10m",
          "wdir10": "windDirection10m"
        } } },
        "delta_time_to_datetime",
        "unify_chunks",
        "save",
        "clean"
      ]
    }
  }
}