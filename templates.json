{
  "arpege": {
    "variables": {
      "lon": "longitude",
      "lat": "latitude",
      "height": "heightAboveGround",
      "time": "valid_time"
    },
    "concat_dim": "step",
    "pipelines": {
      "preprocess": [
        { "type": "process", "name": "load_and_merge_from_grib", "params": {
          "discriminator": ["IP1", "IP2", "IP3", "IP4"],
          "rename_before_merge": [{}, {}, {}, {"z": "z_IP4"}],
          "dataset_backend_kwargs": [{}, {}, {}, {"filter_by_keys": {"shortName": "z"}}]
        }},
        { "type": "process", "name": "keep_variables", "params": { "keep_vars": ["r", "z", "z_IP4", "t", "wdir", "ws", "w", "clwc", "tke"]} },
        { "type": "process", "name": "rename_variables", "params": { "renameMap": {
          "r": "relativeHumidity",
          "z": "geopotential_pressure",
          "z_IP4": "geopotential_potentialVorticity",
          "t": "temperature", 
          "wdir": "windDirection",
          "ws": "windSpeed",
          "w": "verticalVelocity",
          "clwc": "cloudLiquidWaterContent",
          "tke": "turbulentKineticEnergy"
        } } },
        "unify_chunks",
        "save"
      ]
    }
  },
  "arome": {
    "variables": {
      "lon": "longitude",
      "lat": "latitude",
      "height": "heightAboveGround",
      "time": "valid_time"
    },
    "concat_dim": "step",
    "pipelines": {
      "preprocess": [
        { "type": "process", "name": "load_and_merge_from_grib", "params": {
          "discriminator": ["IP1", "IP2", "IP3", "IP4"],
          "dataset_backend_kwargs": [{}, {}, {}, {"filter_by_keys": {"shortName": "tke"}}]
        }},
        { "type": "process", "name": "keep_variables", "params": { "keep_vars": ["r", "z", "t", "wdir", "ws", "w", "clwc", "tke"]} },
        { "type": "process", "name": "rename_variables", "params": { "renameMap": {
          "r": "relativeHumidity",
          "z": "geopotential",
          "t": "temperature", 
          "wdir": "windDirection",
          "ws": "windSpeed",
          "w": "verticalVelocity",
          "clwc": "cloudLiquidWaterContent",
          "tke": "turbulentKineticEnergy"
        } } },
        "unify_chunks",
        "save"
      ]
    }
  }
}